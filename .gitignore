# =========================================================
# EduLITE — Git Ignore
# =========================================================

# -------------------------
# Environment variables
# -------------------------
.env
.env.*
!.env.example

backend/.env
backend/.env.*
!backend/.env.example

frontend/.env
frontend/.env.*
!frontend/.env.example


# -------------------------
# Dependencies
# -------------------------
node_modules/
frontend/node_modules/
backend/node_modules/


# -------------------------
# Electron build output
# -------------------------
out/
release/
build/

*.nupkg
RELEASES


# -------------------------
# Vite build output/cache
# -------------------------
frontend/dist/
frontend/.vite/
.vite/


# -------------------------
# SQLite database files
# -------------------------
*.db
*.db-journal
*.db-shm
*.db-wal

backend/database/edulite.db
backend/database/edulite.db-shm
backend/database/edulite.db-wal


# -------------------------
# Logs
# -------------------------
*.log
logs/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# -------------------------
# Testing and coverage
# -------------------------
coverage/
.nyc_output/


# -------------------------
# Temporary files
# -------------------------
tmp/
temp/
.cache/

*.tmp
*.temp
*.bak
*.swp
*.swo


# -------------------------
# Windows files
# -------------------------
Thumbs.db
Desktop.ini
$RECYCLE.BIN/


# -------------------------
# macOS files
# -------------------------
.DS_Store
.AppleDouble
.LSOverride


# -------------------------
# IDE/editor files
# -------------------------
.vscode/
.idea/

*.code-workspace


# -------------------------
# Electron/native rebuild
# -------------------------
.electron-gyp/
.node-gyp/


# -------------------------
# Certificates and secrets
# -------------------------
*.pfx
*.p12
*.pem
*.key
*.cer
*.crt