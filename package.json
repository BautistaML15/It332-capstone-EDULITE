{
  "name": "edulite-desktop",
  "productName": "EduLITE",
  "version": "1.0.0",
  "description": "EduLITE analytics-based learning support desktop application",
  "author": "EduLITE Development Team",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "start": "concurrently -k -s first \"npm:dev:frontend\" \"npm:dev:electron\"",
    "dev:frontend": "npm --prefix frontend run dev -- --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electron-forge start",
    "build:frontend": "npm --prefix frontend run build",
    "package": "npm run build:frontend && electron-forge package",
    "make": "npm run build:frontend && electron-forge make"
  },
  "dependencies": {
    "@google/genai": "2.11.0",
    "bcrypt": "npm:bcryptjs@3.0.3",
    "better-sqlite3": "12.10.0",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "electron-squirrel-startup": "1.0.1",
    "express": "5.1.0",
    "pdfkit": "0.19.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/maker-squirrel": "7.11.2",
    "@electron-forge/maker-zip": "7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.2",
    "concurrently": "9.2.1",
    "electron": "41.7.1",
    "wait-on": "8.0.3"
  }
}